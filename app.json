{
  "name": "AI Interactive Novel",
  "description": "An AI-powered interactive novel platform where readers can vote to determine the story's direction",
  "keywords": [
    "python",
    "fastapi",
    "ai",
    "novel",
    "interactive"
  ],
  "website": "https://github.com/xbym/xiaoshuo",
  "repository": "https://github.com/xbym/xiaoshuo",
  "success_url": "/",
  "scripts": {
    "postdeploy": "python manage.py init"
  },
  "env": {
    "OPENAI_API_KEY": {
      "description": "Your OpenAI API key",
      "required": true
    },
    "DATABASE_URL": {
      "description": "Database connection URL",
      "required": true
    },
    "TWITTER_API_KEY": {
      "description": "Twitter API key",
      "required": false
    },
    "TWITTER_API_SECRET": {
      "description": "Twitter API secret",
      "required": false
    },
    "TWITTER_ACCESS_TOKEN": {
      "description": "Twitter access token",
      "required": false
    },
    "TWITTER_ACCESS_TOKEN_SECRET": {
      "description": "Twitter access token secret",
      "required": false
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    },
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": [
    "heroku-postgresql:mini"
  ],
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
} 